{
  "coc.preferences.diagnostic.displayByAle": false,
  "diagnostic.enable": false,

  "snippets.ultisnips.directories": ["UltiSnips", "~/.config/nvim/snippets"],
  "snippets.ultisnips.pythonPrompt": false,

  "clangd.arguments": ["--header-insertion=never"],

  "inlayHint.enable": false,
  "clangd.inlayHints.enable": false,

  "tag.files": "tags",
  "coc.preferences.jumpCommand": "tags",
  "coc.source.tag": {
    "enable": true,
    "filetypes": ["cpp", "c", "h"]
  },
  "coc.preferences.filetypeMap": {
    "c": "cpp",
    "hpp": "cpp"
  },

  "coc.preferences.highlight.enable": true,

  "languageserver": {
    "qml": {
      "command": "qmlls",
      "filetypes": ["qml"],
      "rootPatterns": ["CMakeLists.txt", "compile_commands.json"]
    },
    "go": {
      "command": "gopls",
      "args": ["serve"],
      "filetypes": ["go"],
      "settings": {
        "gopls": {
          "usePlaceholders": true,
          "completeUnimported": true,
          "staticcheck": true
        }
      }
    }
  },

  "go.useLanguageServer": true,

  "suggest.enablePreselect": true,
  "suggest.enablePreview": true,
  "suggest.floatEnable": true,
  "suggest.maxPreviewWidth": 80,
  "suggest.border": "rounded",
  "suggest.defaultSortMethod": "recency",
  "suggest.disableKind": false,
  "suggest.disableMenu": true,
  "suggest.detailField": "menu",
  "suggest.floatConfig": {
    "border": "single",
    "winblend": 0,
    "highlight": "Pmenu",
    "scrollbar": true
  }
}
